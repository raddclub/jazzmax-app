# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/
.upm/
.config/

# Python
__pycache__/
*.pyc
*.pyo
.pythonlibs/

# Large binary folders (re-downloaded automatically)
radd-hub/local/

# Logs, temp, backups
radd-hub/data/logs/
radd-hub/data/backups/
radd-hub/data/tmp/
radd-hub/data/staging/
radd-hub/data/media/
radd-hub/data/cache/

# SQLite WAL files (safe to exclude — database is checkpointed before push)
radd-hub/data/radd_hub.db-wal
radd-hub/data/radd_hub.db-shm
radd-hub/data/raddhub.pid

# Secrets / env
.env
.env.local
radd-hub/.env

# Zip exports
jazzmax_*.zip

# JazzMAX keystore (stored as GitHub Secret KEYSTORE_BASE64)
jazzmax_flutter/android/app/keystore/*.keystore
jazzmax_flutter/android/app/keystore/*.jks
jazzmax_flutter/android/app/key.properties

# Python
__pycache__/
*.pyc
.pythonlibs/

# Build artifacts
jazzmax_flutter/build/
