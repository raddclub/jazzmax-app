<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows HTTP (cleartext) traffic to the JazzMAX Oracle production server
  and to localhost (for development). All other traffic requires HTTPS.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Oracle production server -->
        <domain includeSubdomains="false">92.4.95.252</domain>
        <!-- Local development -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
    <!-- All other domains require HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
