modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Radd Hub"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Watch Prototype"

[[workflows.workflow]]
name = "Radd Hub"
author = "agent"

[workflows.workflow.metadata]
agentBlocking = false
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pip3 install -r requirements.txt -q 2>/dev/null | tail -1; cd radd-hub && python3 radd_hub.py run --skip-setup"
waitForPort = 5000

[[workflows.workflow]]
name = "Watch Prototype"
author = "agent"

[workflows.workflow.metadata]
agentBlocking = false
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd _watch_prototype && PORT=8000 python3 run.py"
waitForPort = 8000

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 30000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[nix]
channel = "stable-25_05"
