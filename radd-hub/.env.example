# ─────────────────────────────────────────────────────────────────
# Radd Hub v3.0 — environment configuration
# Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────
PORT=5000
HOST=0.0.0.0
# Optional: set to 1 to enable JSON-structured logs
LOG_JSON=0
LOG_LEVEL=INFO

# ── Admin credentials ────────────────────────────────────────────
# These are auto-generated on first run if left blank.
FLASK_SECRET_KEY=
RADD_ADMIN_USER=admin
RADD_ADMIN_PASS=

# ── Paths ────────────────────────────────────────────────────────
# Default: data/ and data/media/ inside the project folder
DATA_DIR=
MEDIA_DIR=
DOWNLOAD_DIR=

# ── Download defaults ────────────────────────────────────────────
RADD_HEADLESS=1
RADD_PARALLEL_RACE=1
RADD_MAX_PARALLEL=2
RADD_AUTO_INSTALL_ARIA2=1
RADD_AUTO_INSTALL_BROWSER=1

# ── Bots ─────────────────────────────────────────────────────────
ENABLE_WHATSAPP_BOT=0
ENABLE_TELEGRAM_BOT=0
TELEGRAM_BOT_TOKEN=

# ── API Keys (add more via web Settings page) ────────────────────
# Note: keys are stored in the DB via the Settings → Key Vault page.
# These env vars are fallback / bootstrap values only.
TMDB_API_KEY=
OMDB_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=

# ── Mirror destinations ──────────────────────────────────────────
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_DB_PATH=radd_media.json
GSHEET_ID=
GSHEET_NAME=Sheet1
